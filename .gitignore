# ============================================================
# cuiby 项目 .gitignore
# 防止 data, ckpt 等大文件上传到 GitHub
# ============================================================

# -------------------- 数据文件 --------------------
# 数据目录 (序列数据、嵌入缓存等)
**/data/
**/dataset/
**/datasets/

# 嵌入缓存 (pkl 文件非常大，~1.45GB)
**/embeddings_cache/
**/*.pkl

# Gene Ontology 数据库文件 (~30MB each)
**/*.obo

# -------------------- 模型权重/检查点 --------------------
**/ckpt/
**/checkpoint/
**/checkpoints/
**/weights/
**/*.pt
**/*.pth
**/*.bin
**/*.h5
**/*.onnx
**/*.safetensors

# -------------------- 压缩包 --------------------
**/*.tar.gz
**/*.tar.bz2
**/*.tar.xz
**/*.zip

# -------------------- 日志 --------------------
**/logs/
**/log/
**/*.log
**/*.log.*

# -------------------- 测试/评估结果 --------------------
**/test_results/
**/eval/
**/results/

# -------------------- Python --------------------
__pycache__/
**/__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
*.egg
.eggs/
*.so

# 虚拟环境
venv/
.venv/
env/
.env/

# -------------------- LaTeX 编译产物 --------------------
*.aux
*.bbl
*.blg
*.fls
*.fdb_latexmk
*.synctex.gz
*.out
*.toc
*.lot
*.lof
*.idx
*.ilg
*.ind
*.thm
*.xdv
*.nav
*.snm
*.vrb
texput.*

# 保留 .tex, .bib, .cls, .sty, .bst, .cfg 等源文件
# 保留 main.pdf (论文终稿)

# -------------------- IDE / 编辑器 --------------------
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# -------------------- Office 临时文件 --------------------
~$*

# -------------------- TensorBoard --------------------
**/events.out.tfevents.*

# -------------------- 其他大文件 --------------------
# 如有其他大文件，在此添加
